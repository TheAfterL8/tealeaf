{
  "name": "tealeaf-sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript SDK for C2PA content verification. Wraps @contentauth/c2pa-node for use in Node contexts (CLI, server tools).",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node-verifier.d.ts",
      "import": "./dist/node-verifier.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@contentauth/c2pa-node": "^0.5.5",
    "@contentauth/c2pa-types": "^0.7.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
